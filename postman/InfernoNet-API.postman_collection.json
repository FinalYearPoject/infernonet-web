{
  "info": {
    "name": "InfernoNet API",
    "description": "Full end-to-end test suite. Run with Collection Runner in the order shown. IDs are auto-saved to environment variables after each Create request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" }
  ],
  "item": [
    {
      "name": "01 Health",
      "item": [
        {
          "name": "Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('Service healthy', () => pm.expect(b.status).to.eql('healthy'));",
                  "pm.test('Database ok', () => pm.expect(b.database).to.eql('ok'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "02 Organizations",
      "item": [
        {
          "name": "Create organization",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(b.id).to.be.a('string'));",
                  "pm.test('Name matches', () => pm.expect(b.name).to.eql('Central Fire Department'));",
                  "pm.test('Type matches', () => pm.expect(b.type).to.eql('fire_department'));",
                  "pm.environment.set('org_id', b.id);",
                  "console.log('org_id =', b.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Central Fire Department\",\n  \"type\": \"fire_department\",\n  \"contact_phone\": \"+1234567890\",\n  \"address\": \"123 Main St, Los Angeles\"\n}"
            },
            "url": "{{base_url}}/api/organizations"
          }
        },
        {
          "name": "List organizations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('organizations is array', () => pm.expect(b.organizations).to.be.an('array'));",
                  "pm.test('At least 1 org', () => pm.expect(b.organizations.length).to.be.at.least(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/organizations?limit=100"
          }
        },
        {
          "name": "Get organization by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('ID matches', () => pm.expect(b.id).to.eql(pm.environment.get('org_id')));",
                  "pm.test('Has name', () => pm.expect(b.name).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/organizations/{{org_id}}"
          }
        }
      ]
    },
    {
      "name": "03 Users",
      "item": [
        {
          "name": "Create user — coordinator",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(b.id).to.be.a('string'));",
                  "pm.test('Email matches', () => pm.expect(b.email).to.eql('coordinator@infernonet.com'));",
                  "pm.test('Role is coordinator', () => pm.expect(b.role).to.eql('coordinator'));",
                  "pm.test('No password_hash exposed', () => pm.expect(b).to.not.have.property('password_hash'));",
                  "pm.environment.set('coordinator_id', b.id);",
                  "console.log('coordinator_id =', b.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"coordinator@infernonet.com\",\n  \"password\": \"pass1234\",\n  \"full_name\": \"Alice Smith\",\n  \"role\": \"coordinator\",\n  \"phone\": \"+1555000001\",\n  \"organization_id\": \"{{org_id}}\"\n}"
            },
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "Create user — firefighter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(b.id).to.be.a('string'));",
                  "pm.test('Role is firefighter', () => pm.expect(b.role).to.eql('firefighter'));",
                  "pm.environment.set('user_id', b.id);",
                  "console.log('user_id =', b.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"firefighter@infernonet.com\",\n  \"password\": \"pass1234\",\n  \"full_name\": \"John Doe\",\n  \"role\": \"firefighter\",\n  \"phone\": \"+1555000002\",\n  \"organization_id\": \"{{org_id}}\"\n}"
            },
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "Create user — duplicate email (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 on duplicate email', () => pm.response.to.have.status(409));",
                  "const b = pm.response.json();",
                  "pm.test('detail field present', () => pm.expect(b.detail).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"firefighter@infernonet.com\",\n  \"password\": \"otherpass\",\n  \"full_name\": \"Duplicate User\",\n  \"role\": \"civilian\"\n}"
            },
            "url": "{{base_url}}/api/users"
          }
        },
        {
          "name": "List users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('users is array', () => pm.expect(b.users).to.be.an('array'));",
                  "pm.test('At least 2 users', () => pm.expect(b.users.length).to.be.at.least(2));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/users?limit=100"
          }
        },
        {
          "name": "List users — filter by role firefighter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('All roles are firefighter', () => {",
                  "  b.users.forEach(u => pm.expect(u.role).to.eql('firefighter'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/users?role=firefighter"
          }
        },
        {
          "name": "Get user by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('ID matches', () => pm.expect(b.id).to.eql(pm.environment.get('user_id')));",
                  "pm.test('Has email', () => pm.expect(b.email).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/users/{{user_id}}"
          }
        },
        {
          "name": "Get user — not found (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/users/00000000-0000-0000-0000-000000000000"
          }
        }
      ]
    },
    {
      "name": "04 Incidents",
      "item": [
        {
          "name": "Create incident",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(b.id).to.be.a('string'));",
                  "pm.test('Status is active', () => pm.expect(b.status).to.eql('active'));",
                  "pm.test('Severity is high', () => pm.expect(b.severity).to.eql('high'));",
                  "pm.test('Has coordinates', () => {",
                  "  pm.expect(b.latitude).to.be.a('number');",
                  "  pm.expect(b.longitude).to.be.a('number');",
                  "});",
                  "pm.environment.set('incident_id', b.id);",
                  "console.log('incident_id =', b.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Forest fire near Highway 5\",\n  \"description\": \"Large wildfire spreading east, threatening residential areas\",\n  \"severity\": \"high\",\n  \"latitude\": 34.0522,\n  \"longitude\": -118.2437,\n  \"address\": \"Highway 5, mile 42, Los Angeles County\",\n  \"created_by\": \"{{coordinator_id}}\"\n}"
            },
            "url": "{{base_url}}/api/incidents"
          }
        },
        {
          "name": "List incidents",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('incidents is array', () => pm.expect(b.incidents).to.be.an('array'));",
                  "pm.test('At least 1 incident', () => pm.expect(b.incidents.length).to.be.at.least(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/incidents?limit=50"
          }
        },
        {
          "name": "List incidents — filter active",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('All are active', () => {",
                  "  b.incidents.forEach(i => pm.expect(i.status).to.eql('active'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/incidents?status_filter=active"
          }
        },
        {
          "name": "Get incident by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('ID matches', () => pm.expect(b.id).to.eql(pm.environment.get('incident_id')));",
                  "pm.test('Has description', () => pm.expect(b.description).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/incidents/{{incident_id}}"
          }
        },
        {
          "name": "Update incident — status contained",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('Status updated', () => pm.expect(b.status).to.eql('contained'));",
                  "pm.test('Severity updated', () => pm.expect(b.severity).to.eql('medium'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"contained\",\n  \"severity\": \"medium\"\n}"
            },
            "url": "{{base_url}}/api/incidents/{{incident_id}}"
          }
        },
        {
          "name": "Create incident update",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.test('Has id', () => pm.expect(b.id).to.be.a('string'));",
                  "pm.test('incident_id matches', () => pm.expect(b.incident_id).to.eql(pm.environment.get('incident_id')));",
                  "pm.test('status_before is active', () => pm.expect(b.status_before).to.eql('active'));",
                  "pm.test('status_after is contained', () => pm.expect(b.status_after).to.eql('contained'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Fire contained on north flank. Water resources deployed.\",\n  \"user_id\": \"{{coordinator_id}}\",\n  \"status_before\": \"active\",\n  \"status_after\": \"contained\"\n}"
            },
            "url": "{{base_url}}/api/incidents/{{incident_id}}/updates"
          }
        },
        {
          "name": "List incident updates",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('updates is array', () => pm.expect(b.updates).to.be.an('array'));",
                  "pm.test('At least 1 update', () => pm.expect(b.updates.length).to.be.at.least(1));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/incidents/{{incident_id}}/updates"
          }
        }
      ]
    },
